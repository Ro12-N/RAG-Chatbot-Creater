# Creator RAG FastAPI Server Environment Configurations

# 1. API Keys (Provide at least one of these. Gemini is highly recommended for lower cost)
OPENAI_API_KEY=your-openai-api-key-here
GOOGLE_API_KEY=your-gemini-api-key-here

# 2. Vector Store Configuration (ChromaDB runs locally. Set these only if using Pinecone)
# PINECONE_API_KEY=your-pinecone-key
# PINECONE_ENV=us-east-1-aws
# PINECONE_INDEX=creator-rag

# 3. Server configuration
PORT=8000
